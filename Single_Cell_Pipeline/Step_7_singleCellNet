                        expTrain = expTrain, 
                        nTopGenes = 30,
                        nRand = 70, 
                        nTrees = 1000, 
                        nTopGenePairs = 60, 
                        dLevel = 'k.type', 
                        colName_samp = 'cell_ID')

# Validate training
