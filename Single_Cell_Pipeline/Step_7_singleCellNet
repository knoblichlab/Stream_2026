# subset reference to remove small groups and irrelevant cell types 
k.type <- FetchData(k.cts, vars = c('Group', 'Region', 'type_updated')) %>% 
  rownames_to_column(var = 'cell') %>% 
  mutate(new.celltype = case_when(str_detect(type_updated, 'EN')  ~ 'EN', 
                                  str_detect(type_updated, 'Astro') ~ 'Astrocyte', 
                                  str_detect(type_updated, 'Olig') ~ 'Oligodendrocyte', 
                                           .default = type_updated)) %>% 
  mutate(new.reg = case_when(Region == 'Telencephalon' ~ 'Telencephalon', .default = 'Cortical')) %>% 
  mutate(k.type = case_when(str_detect(new.celltype, 'IN') & str_detect(new.celltype, 'Immature') ~ paste0(Group, '_', new.celltype), 
                            str_detect(new.celltype, 'RG') & Region == 'Telencephalon' ~ paste0(Region, '_', new.celltype),
                            .default = new.celltype)) 



kt.counts <- as.data.frame(table(k.type$k.type)) %>% arrange(desc(Freq))

small.groups <- kt.counts %>% dplyr::filter(Freq < 100) %>% droplevels() %>% pull(Var1)

k.cts <- AddMetaData(k.cts, (k.type %>% dplyr::select(cell, k.type) %>% column_to_rownames(var = 'cell')))

kt.counts

# subset for training (matching labels, etc) 
k.train <- subset(k.cts, subset = !(k.type %in% c(small.groups, 'Microglia', 'Vascular', 'Unknown') | Group == 'Adolescence'))

# -- cell net -- # 

commonGenes = intersect(rownames(k.train), rownames(cts.w))
length(commonGenes)

# Subset the reference to shared genes 
k.train = k.train[commonGenes,]

# Table of Sample Metadata 
stRef <- k.train@meta.data
stRef$cell_ID <- colnames(k.train)
droplevels(stRef)

# Get normalized counts as a matrix
k.train <- NormalizeData(k.train)
ref.mtx <- GetAssayData(k.train, layer = 'data')

# Set up for training
set.seed(123)
stList <- splitCommon(sampTab = stRef, ncells = 100, dLevel = 'k.type')
stTrain <- stList[[1]] 
expTrain <- ref.mtx[,rownames(stTrain)]

# Train the classifier 

