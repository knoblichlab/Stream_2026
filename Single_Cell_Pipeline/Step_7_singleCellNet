# Matrix of confidences 
cr.mx <- score.df %>% 
  pivot_wider(values_from = classification_score, names_from = cell_type) 
  

cr.tb <- tibble(cell = cr.mx$cell_ID, 
                xcon = apply((cr.mx %>% dplyr::select(-c(cluster, cell_ID))), 1, c, simplify = F)) %>%
  rowwise() %>%
  mutate(xsort = list(sort(xcon, decreasing = T, index.return = T))) %>% 
  mutate(topN.con = list(xcon[xsort$ix[1:5]]),
         topN.type = list(names(xsort$x[1:min(5, length(xsort))]))) %>% 
  mutate(top.Type = topN.type[1], 
         top.Con = topN.con[1], 
         b.Type = topN.type[2], 
         b.Con = topN.con[2]) %>% 
  mutate(type.Dif = top.Con - b.Con, 
         type.Prop = top.Con/b.Con) %>% 
  mutate(con.score = (type.Dif * 100) * (top.Con * 100)) %>%
  # convert lists into strings
  mutate(topN.con = str_c(topN.con, collapse = ', '), 
         topN.type = str_c(topN.type, collapse = ', ')) %>% 
  dplyr::select(-starts_with('x')) %>% 
  left_join( (cr.mx %>% dplyr::select(cell_ID, cluster)), by = c('cell' = 'cell_ID'))


# summarize totals
sum.calls <- net.df %>%
  group_by(group, category) %>% 
