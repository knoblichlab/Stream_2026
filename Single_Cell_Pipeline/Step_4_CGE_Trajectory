# Analyze CGE subset with Monocle3 

## ----- Load Packages ----- ## 
# Single Cell
require(qs)
require(Seurat)
require(presto)
require(monocle3) # version 3.12

# Data Wrangling
require(tidyverse)
require(forcats)
require(ggplot2)
require(ggrepel)
require(cowplot)
require(ggrepel)
require(patchwork)
require(scales)
require(scattermore)
require(hrbrthemes)

# palettes
cols.clusters <- c(brewer.pal(12, name = 'Set3'), '#689689', '#247BA0',  '#F25F5C', '#ffafcc')
cols.3 <- c('#f7d486','#49beaa', '#f27a7d')
new.scale <- c('#33a8c7','#52e3e1', '#a0e426', '#fdf148', '#ffab00', '#f77976', '#9336fd', '#f050ae', '#d883ff')

## --- Monocle ---- ## 

# load CGE trajectory subset
cts <- qread(file = 'Step1_CGE_Trajectory_LastSubset.qs')

# Convert to celldata frame 

count.mx <- GetAssayData(cts, layer = 'counts') %>% as.matrix() 

meta.data <- FetchData(cts, vars = c('orig.ident', 'nCount_RNA', 'nFeature_RNA', 'percent.mt', 'cge4_hclust_0.5', 'annot_4', 'annot_cluster', 'timepoint'))
gene.data <- data.frame(row.names = row.names(count.mx), 
                        gene_short_name = row.names(count.mx))
# new cds
cds <- new_cell_data_set(count.mx,
                         cell_metadata = meta.data, 
                         gene_metadata = gene.data)

# align by sample
cds <- preprocess_cds(cds, num_dim = 50)
cds <- align_cds(cds, alignment_group = "orig.ident")
cds <- reduce_dimension(cds)

# get trajectory
traj <- plot_cells(cds, label_groups_by_cluster=FALSE,  
           color_cells_by = "annot_4", 
           cell_stroke = 0, 
           group_label_size = 4, 
            label_leaves=FALSE,
           show_trajectory_graph = F, 
           label_branch_points=FALSE,
           label_cell_groups = T,
           cell_size = .8) 

# get partitions 
cds <- cluster_cells(cds)
plot_cells(cds, color_cells_by = "partition", cell_stroke = 0, group_label_size = 4, cell_size = .8) + theme(aspect.ratio = 1)

# Find trajectories
cds <- learn_graph(cds)

cds$layers[[1]]$aes_params$colour <- 'transparent'

## Plot trajectories 
plot_cells(cds,
           color_cells_by = "annot_4",
           label_groups_by_cluster=FALSE,
           label_leaves=FALSE,
           label_branch_points=FALSE, 
           cell_stroke = 0, group_label_size = 4, cell_size = .8) + 
  scale_color_manual(values = cols.clusters) + 
  theme_cowplot() + 
  theme(aspect.ratio = 1)
  
traj.data <- ggplot_build(traj)[["plot"]][["data"]]

ggplot(traj.data, aes(x = data_dim_1, y = data_dim_2, color = annot_4)) + 
  geom_point(size = 0.6) + 
  scale_color_manual(values = brewer.pal(7, name = 'Set3')) + 
  theme_cowplot() + 
  xlab('UMAP1') + 
  ylab('UMAP2') + 
  theme(aspect.ratio = 1) 

plot_cells(cds,
           color_cells_by = "annot_4",
           label_cell_groups=FALSE,
           label_leaves=TRUE,
           label_branch_points=TRUE,
           graph_label_size=1.5, 
           cell_stroke = 0, group_label_size = 4, cell_size = .8) + 
  scale_color_manual(values = cols.clusters) + 
  theme_cowplot() + 
  theme(aspect.ratio = 1)

# psuedotime 
cds <- order_cells(cds)

## plot psuedotime 
plot_cells(cds,
           color_cells_by = "pseudotime",
           label_cell_groups=FALSE,
           label_leaves=FALSE,
           label_branch_points=FALSE,
           graph_label_size=1.5, 
           cell_stroke = 0, cell_size = .8) + 
  theme_cowplot() + 
  theme(aspect.ratio = 1)



