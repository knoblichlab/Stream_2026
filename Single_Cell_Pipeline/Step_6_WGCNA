# enamble multithreading for hdwgcna
enableWGCNAThreads(nThreads = 16)

# load and update object for hdwgcan 
cts <- qread(file = 'Step1_CGE_Trajectory_LastSubset.qs')
cts <- SeuratObject::UpdateSeuratObject(cts)

# Get pseudotime values 
pt.data <- read_tsv(file = 'Step2_PseudotimeValues_CGE_Trajectory.tsv') %>% 
  dplyr::select(cell, pt) %>% 
  column_to_rownames(var = 'cell')

# Partition Data
require(monocle3)
## Load CDS from monocle
cds <- qread(file = 'Step2_CGE_Trajectory_Pseudotime_Monocle.qs')

## Get partition from the plot 
part <- plot_cells(cds, color_cells_by = "partition", cell_stroke = 0, group_label_size = 4, cell_size = .8)

# Make into medatadata column
part.data <- ggplot_build(part)[["plot"]][["data"]] %>% 
  rownames_to_column(var = 'cell') %>% 
  dplyr::rename('partition' = 'cell_color') %>% 
  dplyr::select(cell, partition) %>% 
  column_to_rownames(var = 'cell')

# Add metadata 
cts <- AddMetaData(cts, pt.data)
cts <- AddMetaData(cts, part.data)

# --- hdwgcna --- # 

# Select genes expressed in at least 5% of cells in the dataset (fraction = 0.05)
cts <- SetupForWGCNA(cts, gene_select = 'fraction', fraction = 0.05, wgcna_name = 'CGE')

# Set idents to clusters
Idents(cts) <- 'annot_cluster'

# construct metacells 
cts <- MetacellsByGroups(cts,
                           group.by = c('annot_cluster', 'orig.ident'),
                           reduction = 'cge4_har_default',
                           k = 25, 
                           max_shared = 10, 
                           ident.group = 'annot_cluster')

# Normalize the metacell matrix
cts <- NormalizeMetacells(cts)

# List all groups 
clusters <- c('10_Stream_INs', '2_Late_IN_Immature', '4_Late_CGE_Progenitor', '6_Late_IN_Immature', '7_IN_Progenitor')

#
cts <- SetDatExpr(cts, 
                  group_name = clusters,
                    group.by = 'annot_cluster',
                    assay = 'RNA',
                    layer = 'data')

# select soft power threshold
cts <- TestSoftPowers(cts, networkType = 'signed')

plot.list <- PlotSoftPowers(cts)

wrap_plots(plot.list, ncol = 2)

# Construct the Topological Overlap Matrix (TOM)
cts <- ConstructNetwork(cts, tom_name = 'CGE_Traj_Late_Extended_sp5', soft_power = 5)

PlotDendrogram(cts, main = 'Late CGE Trajectory')

# get module eigengenes
cts <- ModuleEigengenes(cts)

# get connectivity 

cts <- ModuleConnectivity(cts)

cts <- ResetModuleNames(cts, new_name = 'Late_CGE')


p <- PlotKMEs(cts, ncol = 4, n_hubs = 11)

# get module MEs
mod.as.ex <- GetModules(cts)

hub.ex <- GetHubGenes(cts, n_hubs = 25)

# plot against pseudotime 

# pal
pt.comp.palette <- c('#89c2d9', '#e9c46a',  '#f48498',  '#2a9d8f', '#f4a261', '#e76f51', '#7209b7')
# Get MEs by cell 
me.extended <- GetMEs(cts) %>%
  rownames_to_column(var = 'cell')

# Subset to late partition 
plot.df <- FetchData(cts, vars = c('pt', 'annot_4', 'annot_cluster', 'partition')) %>% 
  rownames_to_column(var = 'cell') %>% 
  left_join(me.extended, by = c('cell' = 'cell')) %>% 
  dplyr::filter(partition == '2')


# Plot 
