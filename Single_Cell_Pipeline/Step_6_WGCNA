# intersect with nascimento 
# module 3 genes 
mod3.genes <- read.table(file = 'Step4d_Genes_byModules.tsv', row.names = 1) %>% 
  dplyr::filter(module == 'Late_CGE3')

# nascimento markers 
##nas.markers 

# intersection 
nas.mod3 <- nas.markers %>% 
  dplyr::filter(gene %in% mod3.genes$gene_name) %>% 
  mutate(label = case_when(gene %in% (nas.mod3 %>% arrange(desc = T) %>% head(n = 10))$gene ~ gene, .default = NA), 
         cat = case_when(p_val_adj < 0.05 & avg_log2FC > 1 ~ 'up', 
                         p_val_adj < 0.05 & avg_log2FC < -1 ~ 'down',
                         .default = 'ns'))

# volcano plot
ggplot(nas.mod3, aes(x = avg_log2FC, y = -log(p_val_adj, 10), color = cat, label = label)) +
  geom_point(size = 1) + 
  scale_color_manual(values = c('grey70', '#38b000', '#7209b7')) + 
  geom_hline(yintercept = -log(0.05, 10), color = 'grey50') + 
  geom_vline(xintercept = 1, color = 'grey50') + 
  geom_vline(xintercept = -1, color = 'grey50') + 
  geom_label_repel(size = 3) + 
  xlab('EC Stream Avg Log2FC') + 
  ylab('EC Stream -log10(P.Adj)') + 
  ggtitle('Module 3 Gene Expression in vivo') + 
  theme_cowplot() + 
  panel_border(color = 'black') + 
  theme(aspect.ratio = 1.1, legend.position = 'none')




